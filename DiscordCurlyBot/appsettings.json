{
  "ConnectionStrings": {
    "PostgresDB": "Host=${DB_POSTGRE_HOST};Port=${DB_POSTGRE_PORT};Database=${DB_NAME};Username=${DB_ADMIN_USER};Password=${DB_ADMIN_PASSWORD}",
    "MSSQLDB": "Server=${DB_MSSQL_HOST},${DB_MSSQL_PORT};Database=${DB_NAME};User Id=sa;Password=${DB_ADMIN_PASSWORD};TrustServerCertificate=True;"
  },
  "DiscordToken": "ТВОЙ_ТОКЕН_ДЛЯ_ЛОКАЛЬНОЙ_ОТЛАДКИ",
  "TTS_ENDPOINT": "http://localhost:5000",
  "VoiceSettings": {
    "DebounceDelayMilliseconds": 500,
    "DefaultVoiceModel": "ru_RU-denis-medium.onnx",
    "AnnouncementTemplate": "Приветствуем Охотника {0}!",
    "GroupAnnouncementTemplate": "Приветствуем компанию: {0}!"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
